{
  "name": "oc-sonar-mcp",
  "description": "Connect to SonarQube MCP server to access code quality metrics, issues, and analysis results",
  "version": "1.0.0",
  "mcpServers": {
    "sonarqube": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "sonarqube-mcp-server"
      ],
      "env": {
        "SONARQUBE_TOKEN": "${SONARQUBE_TOKEN}",
        "SONARQUBE_URL": "${SONARQUBE_URL}"
      }
    }
  }
}
